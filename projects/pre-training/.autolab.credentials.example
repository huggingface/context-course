# Copy this file to ~/.autolab/credentials and replace the placeholder values.
# Then load it with:
#   . ~/.autolab/credentials

# Required for managed Hugging Face Jobs runs.
export AUTOLAB_HF_BUCKET="your-huggingface-namespace/autolab-cache"

# Optional operator defaults.
export AUTOLAB_HF_NAMESPACE="your-huggingface-namespace"
export AUTOLAB_HF_PREPARE_FLAVOR="cpu-performance"
export AUTOLAB_HF_PREPARE_TIMEOUT="2h"
export AUTOLAB_HF_EXPERIMENT_FLAVOR="h200"
export AUTOLAB_HF_EXPERIMENT_TIMEOUT="90m"
export AUTOLAB_TRACKIO_PROJECT="autolab"

# Optional overrides:
# export AUTOLAB_HF_CLI="$HOME/.local/bin/hf"
# export AUTOLAB_TRACKIO_BIN="$HOME/.venvs/trackio/bin/trackio"
# export AUTOLAB_HF_SECRETS="HF_TOKEN"
